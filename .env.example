# Server Configuration
PORT=3000

# Supabase Local Simulation / Live Credentials
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
DATABASE_URL=postgresql://postgres:local_dev_password@localhost:54322/postgres

# Gemini API Integration
GEMINI_API_KEY=your-gemini-api-key

# Hostinger Webhook Credentials
WEBHOOK_SECRET=your-hostinger-webhook-verification-secret

# Hostinger SMTP Outbound Credentials
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=no-reply@yourdomain.com
SMTP_PASS=your-smtp-password
